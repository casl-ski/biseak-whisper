              ]
            },
            "accordion_row_ir6mHN": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Quelle est la durée des garanties sur les kits de conversion électrique UGO Cycle?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_jQKrWz": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Les kits de conversion électrique UGO Cycle sont installés sur vos vélos avec l’optique de vous offrir un service exceptionnel visant votre entière satisfaction. Ainsi, tous les kits de conversion électriques UGO Cycle sont couverts par une garantie limitée de (12) douze mois couvrant les pièces et la main-d’œuvre.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
