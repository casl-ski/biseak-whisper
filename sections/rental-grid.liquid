{%- comment -%}
  Displays every product in the chosen collection as a rental booking card.
  Products must be tagged "rental-bike" and linked in the rental app's staff
  admin (/admin/bikes) for availability/booking to actually work — this
  section just renders whatever's in the collection, it doesn't filter by tag.
{%- endcomment -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} rental-grid"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="rental-grid__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.collection != blank and section.settings.collection.products_count > 0 -%}
    <div class="rental-grid__items">
      {%- for product in section.settings.collection.products -%}
        {%- render 'rental-booking-card', product: product -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="rental-grid__empty">Aucun vélo disponible pour le moment.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Grille de location",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos vélos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Doit contenir uniquement des produits tagués \"rental-bike\" et déjà liés dans l'admin de l'app de location (/admin/bikes)."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Grille de location",
      "category": "t:categories.collection"
    }
  ]
}
{% endschema %}
