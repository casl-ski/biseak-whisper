
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="header-top-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;"
>
  <div class="header-top-bar__inner">

    <div class="header-top-bar__left">
      <a href="tel:{{ section.settings.phone_url }}" class="header-top-bar__phone-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>{{ section.settings.phone_display }}</span>
      </a>
      {% if section.settings.contact_url != blank %}
        <a href="{{ section.settings.contact_url }}" class="header-top-bar__contact-link">
          {{ section.settings.contact_label }}
        </a>
      {% endif %}
    </div>

    <div class="header-top-bar__right">
      <form action="{{ routes.search_url }}" method="get" role="search" class="header-top-bar__search-form">
        <button type="submit" class="header-top-bar__search-btn" aria-label="Rechercher">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <input
          type="search"
          name="q"
          placeholder="{{ section.settings.search_placeholder }}"
          class="header-top-bar__search-input"
          aria-label="{{ section.settings.search_placeholder }}"
        >
      </form>

      <div class="header-top-bar__social">
        {% if section.settings.facebook_url != blank %}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" class="header-top-bar__social-link" aria-label="Facebook">
            {% render 'icon', icon: 'facebook' %}
          </a>
        {% endif %}
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" class="header-top-bar__social-link" aria-label="Instagram">
            {% render 'icon', icon: 'instagram' %}
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</div>

<script>
  (function () {
    function init() {
      var bar = document.querySelector('.header-top-bar-section');
      if (!bar) return;
      function update() {
        document.documentElement.style.setProperty('--header-top-bar-height', bar.offsetHeight + 'px');
      }
      new ResizeObserver(update).observe(bar);
      update();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% stylesheet %}
  /* Make our bar sticky, stacked above the main header */
  .header-top-bar-section {
    position: sticky;
    top: 0;
    z-index: calc(var(--layer-sticky) + 1);
  }

  /* Push the main header's sticky anchor down so it sits below our bar */
  #header-group > .header-section:has(> #header-component[sticky='always']) {
    top: calc(var(--header-top-bar-height, 0px) - 1px);
  }

  #header-group > .header-section:has(> #header-component[sticky='scroll-up'][data-sticky-state='active']) {
    top: calc(var(--header-top-bar-height, 0px) - 1px);
  }

  .header-top-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .header-top-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .header-top-bar__left,
  .header-top-bar__right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header-top-bar__phone-link,
  .header-top-bar__contact-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.875rem;

    &:hover {
      text-decoration: underline;
    }
  }

  .header-top-bar__contact-link::before {
    content: '|';
    opacity: 0.4;
    margin-inline-end: 0.1rem;
  }

  .header-top-bar__search-form {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 30%, transparent);
    padding-block-end: 2px;
  }

  .header-top-bar__search-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .header-top-bar__search-input {
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-foreground);
    font-size: 0.875rem;
    font-family: inherit;
    width: 140px;

    &::placeholder {
      color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
    }
  }

  .header-top-bar__social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-top-bar__social-link {
    display: flex;
    align-items: center;
    color: var(--color-foreground);
    opacity: 0.8;

    svg {
      width: 18px;
      height: 18px;
    }

    &:hover {
      opacity: 1;
    }
  }

  @media screen and (max-width: 749px) {
    .header-top-bar__inner {
      justify-content: center;
    }

    .header-top-bar__right {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Barre supérieure",
  "class": "header-top-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Téléphone"
    },
    {
      "type": "text",
      "id": "phone_display",
      "label": "Numéro affiché",
      "default": "418 764-6016"
    },
    {
      "type": "text",
      "id": "phone_url",
      "label": "Lien téléphone (chiffres seulement)",
      "default": "4187646016"
    },
    {
      "type": "header",
      "content": "Lien Contact"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Texte du lien",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "URL de contact"
    },
    {
      "type": "header",
      "content": "Recherche"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Texte indicatif",
      "default": "Rechercher..."
    },
    {
      "type": "header",
      "content": "Réseaux sociaux"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "URL Facebook"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "URL Instagram"
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largeur",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Pleine largeur" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Palette de couleurs"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Épaisseur du séparateur",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Haut",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bas",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Barre supérieure"
    }
  ]
}
{% endschema %}
